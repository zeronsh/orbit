{
  "name": "@zeronsh/orbit",
  "version": "0.3.10",
  "description": "Orbit — a Rust rebuild of Zero. Type-safe sync client, React bindings, server helpers, and Drizzle schema generation, all under one tree-shakeable package.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zeronsh/orbit.git",
    "directory": "packages/orbit"
  },
  "homepage": "https://github.com/zeronsh/orbit#readme",
  "sideEffects": false,
  "exports": {
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./server/pg": {
      "types": "./dist/server/pg.d.ts",
      "import": "./dist/server/pg.js"
    },
    "./orm-core": {
      "types": "./dist/orm-core.d.ts",
      "import": "./dist/orm-core.js"
    },
    "./drizzle": {
      "types": "./dist/drizzle.d.ts",
      "import": "./dist/drizzle.js"
    },
    "./drizzle/cli": {
      "types": "./dist/drizzle/cli.d.ts",
      "import": "./dist/drizzle/cli.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "orbit-drizzle": "./dist/drizzle/cli/bin.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node --test --experimental-strip-types",
    "prepublishOnly": "tsup"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.0.0",
    "commander": "^14.0.0"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.36.0",
    "pg": "^8",
    "prettier": ">=3.0.0",
    "react": ">=18",
    "ts-morph": ">=24.0.0"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "prettier": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "ts-morph": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/pg": "^8",
    "@types/react": "^19",
    "drizzle-orm": "1.0.0-rc.3",
    "pg": "^8",
    "react": "^19",
    "react-test-renderer": "^19",
    "ts-morph": "^27.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0"
  }
}
